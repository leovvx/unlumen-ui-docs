          "Neutral": "neutral",
          "Default": "default",
          "Ghost": "ghost",
          "Outline": "outline",
          "Secondary": "secondary"
        }
      },
      "size": {
        "type": "select",
        "label": "Size",
        "default": "icon-sm",
        "options": {
          "Icon SM": "icon-sm",
          "Icon": "icon",
          "SM": "sm"
        }
      }
    }
  }
