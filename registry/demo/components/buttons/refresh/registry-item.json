{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "demo-refresh",
  "type": "registry:example",
  "title": "Refresh Button Demo",
  "registryDependencies": ["@unlumen-ui/refresh"],
  "dependencies": ["lucide-react"],
  "files": [
    {
