          "value": "rotate",
          "options": {
            "Rotate": "rotate",
            "Pulse": "pulse",
            "Breathe": "breathe",
            "Color Shift": "colorShift",
            "Flow Horizontal": "flowHorizontal",
            "Static": "static"
          }
        },
        "blur": {
          "value": "strong",
          "options": {
            "Soft": "soft",
            "Medium": "medium",
            "Strong": "strong",
            "Stronger": "stronger"
          }
        },
        "duration": {
          "value": 5,
          "min": 1,
          "max": 20,
          "step": 0.5
        },
        "glowScale": {
          "value": 1,
          "min": 0.8,
          "max": 1.5,
          "step": 0.05
        }
      }
    }
  }
}
