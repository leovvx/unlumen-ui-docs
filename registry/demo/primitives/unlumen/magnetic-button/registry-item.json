{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "demo-magnetic-button",
  "type": "registry:example",
  "title": "Magnetic Button Demo",
  "description": "Three magnetic buttons showing different radius and spring configurations.",
  "registryDependencies": ["@unlumen-ui/magnetic-button"],
  "files": [
    {
      "path": "registry/demo/primitives/unlumen/magnetic-button/index.tsx",
      "type": "registry:example"
    }
  ],
  "meta": {
    "demoProps": {
      "MagneticButtonDemo": {
