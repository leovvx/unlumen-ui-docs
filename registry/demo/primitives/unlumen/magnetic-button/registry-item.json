          "options": {
            "Default": "default",
            "Secondary": "secondary",
            "Outline": "outline",
            "Ghost": "ghost",
            "Destructive": "destructive"
          }
        },
        "size": {
          "value": "default",
          "options": {
            "Small": "sm",
            "Default": "default",
            "Large": "lg"
          }
        }
      }
    }
  }
}
